{
  "name": "saturn",
  "private": true,
  "version": "0.1.0",
  "description": "Autonomous Infrastructure Management Platform — powered by Ares Neural Engine & ContextP Memory",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop saturn",
    "restart": "pm2 restart saturn",
    "build": "vite build",
    "deploy": "npm run build && npm run start",
    "preview": "vite preview",
    "lint": "tsc --noEmit && eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "madge": "madge --circular src/",
    "unused": "unimported",
    "spellcheck": "cspell 'src/**/*.{ts,tsx}'",
    "setup": "tsx scripts/setup.ts",
    "lint:security": "eslint src/ --ext .ts,.tsx --rules \"security/detect-object-injection: error\"",
    "audit": "npm audit"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1041.0",
    "@aws-sdk/client-ssm": "^3.1041.0",
    "@azure/arm-compute": "^24.0.0",
    "@azure/identity": "^4.13.1",
    "@google-cloud/compute": "^6.9.1",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "enquirer": "^2.4.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-ssh": "^13.2.1",
    "nodemailer": "^8.0.7",
    "picocolors": "^1.1.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "cspell": "^10.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "unimported": "^1.31.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
