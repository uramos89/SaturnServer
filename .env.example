# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional, for OpenAI fallback
OPENAI_API_KEY=""

# APP_URL: URL where this app is hosted
APP_URL="http://localhost:3000"

# JWT_SECRET: Secret for signing JWT tokens (Required)
JWT_SECRET="generate-a-random-32-char-secret"

# SATURN_MASTER_KEY: Key for AES-256-GCM Vault encryption (Required)
SATURN_MASTER_KEY="change-this-to-a-very-long-and-secure-secret"

# MOONSHOT_API_KEY: Optional, for Kimi AI
MOONSHOT_API_KEY=""

# SSH_ENCRYPTION_PEPPER: Pepper for encrypting SSH credentials at rest
SSH_ENCRYPTION_PEPPER="change-this-to-a-random-secret"

# GitHub Personal Access Token (for ContextP sync)
GITHUB_TOKEN=""

# Docker: SSH key mount path (Linux default: ~/.ssh, Windows: C:/Users/you/.ssh)
SSH_KEY_PATH="~/.ssh"
