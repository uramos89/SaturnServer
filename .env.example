# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional, for OpenAI fallback
OPENAI_API_KEY=""

# APP_URL: URL where this app is hosted
APP_URL="http://localhost:3000"

# SSH_ENCRYPTION_PEPPER: Pepper for encrypting SSH credentials at rest
SSH_ENCRYPTION_PEPPER="change-this-to-a-random-secret"

# Litestream: S3-compatible backup (optional)
LITESTREAM_ACCESS_KEY_ID=""
LITESTREAM_SECRET_ACCESS_KEY=""
LITESTREAM_REPLICA_URL=""

# GitHub Personal Access Token (for ContextP sync)
GITHUB_TOKEN=""

# Docker: SSH key mount path (Linux default: ~/.ssh, Windows: C:/Users/you/.ssh)
SSH_KEY_PATH="~/.ssh"
