# ═══════════════════════════════════════════════════════════════════════
# SATURN SERVER — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════

# ── Network ───────────────────────────────────────────────────────────
PORT=3000
APP_URL="http://localhost:3000"
NODE_ENV=production

# ── AI Provider Configuration ─────────────────────────────────────────
# Saturn is provider-agnostic. Configure any of the following:
#   AI_PROVIDER: The active provider ID (e.g. openai, google, anthropic, ollama, custom)
#   {PROVIDER}_API_KEY: API key for the provider (uppercase provider ID)
#   {PROVIDER}_MODEL: Model name override
#   AI_ENDPOINT: Custom endpoint URL (for OpenAI-compatible / self-hosted)

# Active provider
AI_PROVIDER="google"
ACTIVE_AI_PROVIDER="google"

# Provider-specific API keys (only the active one needs to be set)
# GEMINI_API_KEY=""       # Google Gemini (legacy, use GOOGLE_API_KEY)
# GOOGLE_API_KEY=""
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# MOONSHOT_API_KEY=""
# DEEPSEEK_API_KEY=""
# MISTRAL_API_KEY=""
# GROQ_API_KEY=""

# Provider-specific model overrides
# GOOGLE_MODEL="gemini-2.0-flash"
# OPENAI_MODEL="gpt-4o"
# ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Custom endpoint (for self-hosted / custom OpenAI-compatible)
# AI_ENDPOINT="http://localhost:11434"

# ── Security ──────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-secret"
SSH_ENCRYPTION_PEPPER="change-this-to-a-random-secret"
SATURN_MASTER_KEY="change-this-to-a-random-secret"

# ── Optional Features ────────────────────────────────────────────────
GITHUB_TOKEN=""
SSH_KEY_PATH="~/.ssh"
SATURN_API_TOKEN=""
